# ===== Claude API =====
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ===== Kling AI =====
# 신규 단일 API Key 방식 (권장) - kling.ai/dev/api-key 에서 "New API Key"로 발급
KLING_API_KEY=your_kling_api_key
# (선택) 도메인 - 기본값 api-singapore.klingai.com. 중국 내 서버면 api.klingai.com 등으로 변경
# KLING_API_BASE=https://api-singapore.klingai.com
# (레거시) 3.0 이전 모델용 AccessKey/SecretKey - 위 API Key가 없을 때만 사용
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# ===== 팩트체크: Google Custom Search (선택) =====
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
GOOGLE_CSE_ID=your_cse_id

# ===== Google Sheets =====
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service_account.json
GOOGLE_SHEETS_ID=your_google_sheets_id

# ===== Gmail (뉴스레터 발송) =====
GMAIL_USER=youremail@gmail.com
GMAIL_PASSWORD=your_gmail_app_password

# ===== 뉴스레터 수신자 (콤마 구분, 선택) =====
NEWSLETTER_RECIPIENTS=user1@example.com,user2@example.com

# ===== Reddit 스크래핑 (선택) =====
# old.reddit.com 스크래핑용 User-Agent. 기본값은 일반 Chrome UA.
# REDDIT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
